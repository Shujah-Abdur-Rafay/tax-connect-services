# =============================================================================
# functions/.env.example — template for the Cloud Functions runtime secrets.
# Copy to functions/.env and fill in real values. functions/.env is gitignored.
# =============================================================================
# The Firebase CLI loads functions/.env at deploy time (and the emulator reads
# it locally), exposing each value as process.env.<NAME> in the functions.

# ── RESEND — primary transport for every notification email ──────────────────
# Create a key at https://resend.com/api-keys. RESEND_FROM must be a sender on
# a domain you have VERIFIED in Resend, e.g. "Refund Connect <notify@yourdomain.com>".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Refund Connect <notifications@your-domain.com>

# ── Stripe (server) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXX

# ── Legacy Gmail SMTP — optional fallback when RESEND_API_KEY is unset ────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Misc ─────────────────────────────────────────────────────────────────────
ONBOARDING_URL=https://www.refund-connect.com/onboarding

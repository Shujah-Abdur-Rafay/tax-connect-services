{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "esModuleInterop": true,
    // Don't typecheck third-party .d.ts files in node_modules. Some transitive
    // dev-dependency type packages (e.g. @types/rimraf → glob) ship typings
    // newer than the pinned TypeScript 4.9 can parse; skipping lib checks keeps
    // the build green without affecting type-safety of our own source.
    "skipLibCheck": true
  },
  "compileOnSave": true,
  "include": [
    "src"
  ]
}

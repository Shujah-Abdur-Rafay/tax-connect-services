# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id


# ─────────────────────────────────────────────────────────────────────────────
# Email notifications — RESEND
# ─────────────────────────────────────────────────────────────────────────────
# Resend is the transport for EVERY notification email in the app. The API key
# is a SERVER secret and is read by the Cloud Functions from functions/.env
# (NOT shipped to the browser). RESEND_FROM must be a verified sender/domain.
#
#   functions/.env:
#     RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
#     RESEND_FROM=Refund Connect <notifications@your-domain.com>
#
# (You may also set them via Firebase config:
#   firebase functions:config:set resend.api_key="re_..." resend.from="...")
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Refund Connect <notifications@your-domain.com>


# ─────────────────────────────────────────────────────────────────────────────
# App notification routing (frontend)
# ─────────────────────────────────────────────────────────────────────────────
VITE_PLATFORM_OWNER_EMAIL=owner@your-domain.com
VITE_SUPPORT_EMAIL=support@your-domain.com
VITE_KICKOFF_CALENDAR_URL=https://your-domain.com/support
VITE_MEMBER_DASHBOARD_URL=https://your-domain.com/member-portal


# ─────────────────────────────────────────────────────────────────────────────
# Stripe Configuration
# ─────────────────────────────────────────────────────────────────────────────

# PUBLISHABLE key — safe to expose in the frontend bundle.
# Starts with pk_live_ (production) or pk_test_ (test mode).
# Used by src/lib/stripe.ts via loadStripe().
#
# NOTE: The onboarding membership payment step (MembershipPaymentStep.tsx) now
# ALSO accepts the publishable key returned at runtime by the
# `create-payment-intent` Supabase edge function (it reads the server's
# STRIPE_PUBLISHABLE_KEY secret), so card payments work even if this build-time
# var is left as a placeholder. Setting this is still recommended so OTHER
# payment surfaces (BookingPaymentForm, PaymentForm, etc.) initialise Stripe.js.
# IMPORTANT: this key MUST belong to the SAME Stripe account as
# STRIPE_SECRET_KEY, otherwise the client_secret will not be recognised.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXX


# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE Stripe secrets — DO NOT put these in any VITE_* variable.
# They MUST NEVER ship in the frontend bundle.
#
# In production they are read from Firebase Functions config:
#   functions.config().stripe.secret
#   functions.config().stripe.webhook_secret
#
# Set them once per environment with:
#   firebase functions:config:set \
#     stripe.secret="sk_live_XXXXXXXX" \
#     stripe.webhook_secret="whsec_XXXXXXXX"
#   firebase deploy --only functions
#
# The variables below are ONLY consulted as a fallback when running the
# Firebase emulator locally (functions/src/index.ts checks process.env.*).
# Leave them blank in committed .env files.
# ─────────────────────────────────────────────────────────────────────────────

# Stripe SECRET key (sk_live_... or sk_test_...). Local emulator only.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...). Local emulator only.
# Get this from the Stripe Dashboard → Developers → Webhooks → your endpoint.
STRIPE_WEBHOOK_SECRET=

